# ZaFrame Backend — переменные для продакшена
# Скопируйте в .env и заполните (для деплоя задайте в панели Railway/Render/Neon).

# === Обязательно для продакшена ===
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?sslmode=require
SECRET_KEY=сгенерируйте_32_символа_openssl_rand_hex_32

# Base URL of the frontend (no trailing slash). Magic links are built from this.
# Local dev: http://localhost:3000 (or your Vite port)
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
# Разрешённые origins для CORS (через запятую).
# Локально: не задавай — в коде есть дефолт для localhost:3000,5173 и др.
# Продакшен: укажи URL фронта, например https://your-app.vercel.app
# CORS_ORIGINS=https://your-app.vercel.app

# === Опционально ===
# RESEND_API_KEY=re_xxx
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
