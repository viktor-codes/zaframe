# ZeeFrame Frontend — environment variables
#
# Next.js loads (in order): .env → .env.local → .env.[NODE_ENV] → .env.[NODE_ENV].local
# For `next dev`, you can keep values in `.env.development` (committed as a team default)
# or copy this file to `.env.local` (usually gitignored) for machine-specific overrides.

# Required: backend base URL (no trailing slash). The app expects a running API.
# Production: set in your host's environment (e.g. Vercel) to your API origin.
# NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Local development (next dev) — see also `.env.development` in this repo:
# Use the same origin as this Next app so requests go through rewrites in next.config.ts
# to FastAPI and refresh-token cookies stay on localhost:3000.
# NEXT_PUBLIC_API_URL=http://localhost:3000
# Pointing the browser straight at :8000 often breaks cookies across ports.
