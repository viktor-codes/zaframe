# Пример .env.local для ZeeFrame Frontend
# Скопируйте в .env.local и при необходимости измените

# Режим «только лендинг» (деплой без бэкенда):
#   Не задавайте NEXT_PUBLIC_API_URL — будет показана только главная страница.
#   Маршруты /studios, /dashboard, /bookings, /auth перенаправляются на /.

# Режим с бэкендом:
#   Локально с `next dev`: используйте тот же origin, что и фронт (см. .env.development),
#   чтобы запросы шли через rewrite на FastAPI и куки refresh-токена сохранялись.
#   Прямой URL на :8000 без прокси часто даёт пустые куки между разными портами.
#   Продакшен: полный URL API в Environment Variables (Vercel и т.д.).
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
